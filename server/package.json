{
  "name": "carlcare-crm-server",
  "version": "0.1.0",
  "private": true,
  "description": "API REST do CRM Carlcare — Express + SQLite, arquitetura em camadas",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/migrate.ts && tsx src/db/seed.ts",
    "db:clear": "tsx src/db/clear.ts",
    "user:add": "tsx src/scripts/create-user.ts",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.3",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2",
    "vitest": "^3.0.5"
  }
}
